srcFiles = unitTests.cpp

objFiles = $(srcFiles:.cpp=.o)

CXX = $(cname)
CXXFLAGS = $(cflags)

# Tell make to search other paths. Separate multiple with ":"
VPATH = ../../src/test

.PHONY : test
test : $(objFiles)
	$(cname) $(cflags) -o runUnitTests $(objFiles) $(module_libs) -lgtest -lgtest_main
	./runUnitTests

-include ../makefile_std_dep